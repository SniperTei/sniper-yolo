# ====================================
# Sniper YOLO Backend 环境配置模板
# 使用方法: cp .env.example .env.dev
# ====================================

# ---------- 应用配置 ----------
API_V1_STR=/api/v1
PROJECT_NAME=Sniper YOLO Backend
VERSION=1.0.1
DESCRIPTION=FastAPI backend for Sniper YOLO application
ENVIRONMENT=development
DEBUG=true

# ---------- 服务器配置 ----------
HOST=0.0.0.0
PORT=8000

# ---------- 安全配置 ----------
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# ---------- CORS 配置 ----------
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------- 数据库配置 ----------
DATABASE_URL=postgresql+asyncpg://sniper:your_password@127.0.0.1:5432/sniper_yolo
ALEMBIC_DATABASE_URL=postgresql+psycopg2://sniper:your_password@127.0.0.1:5432/sniper_yolo

# ---------- YOLO 配置 ----------
YOLO_MODEL_PATH=./models/yolo.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45

# ---------- 智谱 BigModel LLM 配置 ----------
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_DEFAULT_MODEL=glm-5.1

# ---------- 七牛云配置 ----------
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET_NAME=
QINIU_DOMAIN=
QINIU_DEFAULT_FOLDER=uploads
QINIU_UPLOAD_URL=https://up-z2.qiniup.com
USE_HTTPS=false

# ---------- 文件上传配置 ----------
MAX_FILE_SIZE=5242880

# ---------- 超级管理员配置 (init_superuser.py 使用) ----------
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=changeme
